generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ABTest {
  id            String          @id
  name          String
  description   String?
  status        String          @default("draft")
  winnerId      String?
  winnerReason  String?
  startDate     DateTime?
  endDate       DateTime?
  completedAt   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime
  ABTestVariant ABTestVariant[]
}

model ABTestVariant {
  id             String   @id
  name           String
  trafficPercent Int
  impressions    Int      @default(0)
  clicks         Int      @default(0)
  leads          Int      @default(0)
  conversions    Int      @default(0)
  revenue        Float    @default(0)
  createdAt      DateTime @default(now())
  abTestId       String
  offerId        String
  Offer          Offer    @relation(fields: [offerId], references: [id])
  ABTest         ABTest   @relation(fields: [abTestId], references: [id], onDelete: Cascade)
}

model AIActionLog {
  id           String   @id
  action       String
  entityType   String
  entityId     String?
  input        String?
  output       String?
  duration     Int?
  tokensUsed   Int?
  model        String?
  status       String
  errorMessage String?
  debugInfo    String?
  userId       String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([status])
  @@index([action])
}

model AIDialog {
  id              String            @id
  title           String?
  isPinned        Boolean           @default(false)
  userId          String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  User            User              @relation(fields: [userId], references: [id])
  AIDialogMessage AIDialogMessage[]

  @@index([isPinned])
  @@index([userId])
}

model AIDialogMessage {
  id         String   @id
  role       String
  content    String
  actions    String?
  tokensUsed Int      @default(0)
  provider   String?
  isCached   Boolean  @default(false)
  dialogId   String
  createdAt  DateTime @default(now())
  AIDialog   AIDialog @relation(fields: [dialogId], references: [id], onDelete: Cascade)

  @@index([dialogId])
}

model AIGeneratedContent {
  id              String   @id
  contentType     String
  prompt          String?
  generatedText   String?
  generatedImage  String?
  aiModel         String?
  aiProvider      String?
  niche           String?
  geo             String?
  style           String?
  language        String   @default("ru")
  usedInMethod    String?
  usedInExecution String?
  useCount        Int      @default(0)
  createdAt       DateTime @default(now())
  influencerId    String?

  @@index([contentType])
  @@index([influencerId])
}

model AIGlobalSettings {
  id                  String   @id
  autoFallback        Boolean  @default(true)
  notifyOnSwitch      Boolean  @default(true)
  telegramNotify      Boolean  @default(false)
  useCheapestModel    Boolean  @default(false)
  minBalanceForSwitch Float    @default(5.0)
  dailyLimit          Float?
  monthlyLimit        Float?
  createdAt           DateTime @default(now())
  updatedAt           DateTime
  userId              String
  User                User     @relation(fields: [userId], references: [id])
}

model AIPodcast {
  id              String    @id
  title           String
  description     String?
  audioUrl        String?
  duration        Int?
  script          String?
  language        String    @default("ru")
  voices          String?
  backgroundMusic String?
  introOutro      Boolean   @default(false)
  status          String    @default("draft")
  isPublished     Boolean   @default(false)
  publishedAt     DateTime?
  plays           Int       @default(0)
  likes           Int       @default(0)
  shares          Int       @default(0)
  userId          String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime

  @@index([userId])
  @@index([status])
}

model AIPromptCache {
  id          String   @id
  cacheKey    String   @unique
  prompt      String
  context     String?
  response    String
  tokensUsed  Int      @default(0)
  timesUsed   Int      @default(1)
  tokensSaved Int      @default(0)
  model       String?
  provider    String?
  createdAt   DateTime @default(now())
  lastUsedAt  DateTime @default(now())

  @@index([lastUsedAt])
  @@index([cacheKey])
}

model AIProviderSettings {
  id              String       @id
  provider        String
  apiKey          String?
  defaultModel    String?
  priority        Int          @default(1)
  isActive        Boolean      @default(false)
  lastCheckAt     DateTime?
  lastCheckStatus String?
  lastCheckError  String?
  lastCheckTime   Int?
  balance         Float?
  balanceCurrency String?
  isFree          Boolean      @default(false)
  dailyQuota      Int?
  dailyUsed       Int          @default(0)
  requestsCount   Int          @default(0)
  successCount    Int          @default(0)
  errorCount      Int          @default(0)
  totalTokensIn   Int          @default(0)
  totalTokensOut  Int          @default(0)
  totalCost       Float        @default(0)
  models          String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime
  quotaResetAt    DateTime?
  userId          String
  User            User         @relation(fields: [userId], references: [id])
  AIQuotaLog      AIQuotaLog[]

  @@unique([provider, userId])
  @@index([isActive])
  @@index([provider])
  @@index([userId])
}

model AIQuotaLog {
  id                 String              @id
  provider           String
  date               DateTime            @default(now())
  requestsCount      Int                 @default(0)
  tokensIn           Int                 @default(0)
  tokensOut          Int                 @default(0)
  estimatedCost      Float               @default(0)
  providerSettingsId String?
  AIProviderSettings AIProviderSettings? @relation(fields: [providerSettingsId], references: [id])

  @@unique([provider, date])
}

model AIStyleRating {
  id              String   @id
  userId          String   @unique
  overallRating   Int      @default(0)
  toneMatch       Int      @default(0)
  styleMatch      Int      @default(0)
  audienceMatch   Int      @default(0)
  timingMatch     Int      @default(0)
  ratingsHistory  String?
  totalEdits      Int      @default(0)
  positiveEdits   Int      @default(0)
  learnedPatterns String?
  lastCalculated  DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime

  @@index([overallRating])
  @@index([userId])
}

model Account {
  id                 String               @id
  platform           String
  username           String?
  phone              String?
  email              String?
  password           String?
  sessionData        String?
  apiId              String?
  apiHash            String?
  proxyType          String?
  proxyHost          String?
  proxyPort          Int?
  proxyUsername      String?
  proxyPassword      String?
  browserProfileId   String?
  fingerprint        String?
  status             String               @default("pending")
  banReason          String?
  warmingStartedAt   DateTime?
  warmingEndsAt      DateTime?
  warmingProgress    Int                  @default(0)
  dailyComments      Int                  @default(0)
  dailyDm            Int                  @default(0)
  dailyFollows       Int                  @default(0)
  dailyLikes         Int                  @default(0)
  maxComments        Int                  @default(50)
  maxDm              Int                  @default(20)
  maxFollows         Int                  @default(100)
  banRisk            Int                  @default(0)
  floodUntil         DateTime?
  simCardId          String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime
  lastUsedAt         DateTime?
  userId             String
  SimCard            SimCard?             @relation(fields: [simCardId], references: [id])
  User               User                 @relation(fields: [userId], references: [id])
  AccountAction      AccountAction[]
  AccountRiskHistory AccountRiskHistory[]
  AntidetectBrowser  AntidetectBrowser[]
  Influencer         Influencer[]
  OFMProfile         OFMProfile[]

  @@index([lastUsedAt])
  @@index([simCardId])
  @@index([platform])
  @@index([status])
  @@index([userId])
}

model AccountAction {
  id         String   @id
  actionType String
  target     String?
  result     String?
  error      String?
  createdAt  DateTime @default(now())
  accountId  String
  Account    Account  @relation(fields: [accountId], references: [id])
}

model AccountForSale {
  id              String    @id
  accountId       String    @unique
  platform        String
  niche           String?
  geo             String?
  ageDays         Int       @default(0)
  followersCount  Int       @default(0)
  warmingDays     Int       @default(3)
  warmingComplete Boolean   @default(false)
  warmingProgress Int       @default(0)
  costPrice       Float     @default(0)
  salePrice       Float     @default(0)
  currency        String    @default("USD")
  status          String    @default("warming")
  buyerId         String?
  soldAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime
}

model AccountLegend {
  id            String   @id
  accountId     String?
  influencerId  String?
  age           Int?
  city          String?
  occupation    String?
  hobbies       String?
  bio           String?
  channelId     String?
  channelTheme  String?
  adaptedBio    String?
  autoGenerated Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime
}

model AccountOrder {
  id           String    @id
  platform     String
  niche        String?
  geo          String?
  ageDays      Int?
  minFollowers Int?
  offeredPrice Float
  currency     String    @default("RUB")
  status       String    @default("open")
  fulfilledAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime
}

model AccountRiskHistory {
  id           String   @id
  date         DateTime
  riskScore    Int
  riskFactors  String?
  changeReason String?
  createdAt    DateTime @default(now())
  accountId    String
  Account      Account  @relation(fields: [accountId], references: [id])
}

model Achievement {
  id              String            @id
  code            String            @unique
  name            String
  description     String
  icon            String
  category        String
  points          Int               @default(10)
  difficulty      Int               @default(1)
  condition       String
  isHidden        Boolean           @default(false)
  sortOrder       Int               @default(0)
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  UserAchievement UserAchievement[]

  @@index([isActive])
  @@index([category])
  @@index([code])
}

model ActionLog {
  id         String   @id
  action     String
  entityType String
  entityId   String?
  details    String?
  createdAt  DateTime @default(now())
  userId     String
  User       User     @relation(fields: [userId], references: [id])
}

model ActivityLog {
  id         String   @id
  type       String
  message    String
  campaignId String?
  accountId  String?
  userId     String?
  metadata   String?
  createdAt  DateTime @default(now())

  @@index([accountId])
  @@index([campaignId])
  @@index([type])
  @@index([createdAt])
}

model AffiliateGapScanner {
  id                  String    @id
  network             String
  gapType             String
  description         String?
  estimatedROI        Float     @default(0)
  riskLevel           String    @default("medium")
  recommendedOffer    String?
  recommendedApproach String?
  testedBy            Int       @default(0)
  successRate         Float     @default(0)
  status              String    @default("active")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime
  expiresAt           DateTime?
}

model AnalyticsChannel {
  id             String    @id
  channelId      String    @unique
  channelName    String?
  comments       Int       @default(0)
  clicks         Int       @default(0)
  conversions    Int       @default(0)
  revenue        Float     @default(0)
  conversionRate Float     @default(0)
  periodStart    DateTime
  periodEnd      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime
}

model AnalyticsComment {
  id             String   @id
  text           String
  views          Int      @default(0)
  clicks         Int      @default(0)
  conversions    Int      @default(0)
  ctr            Float    @default(0)
  conversionRate Float    @default(0)
  campaignId     String?
  channelId      String?
  createdAt      DateTime @default(now())
}

model AnalyticsSettings {
  id                 String   @id
  userId             String
  collectViews       Boolean  @default(true)
  collectLikes       Boolean  @default(true)
  collectComments    Boolean  @default(true)
  collectShares      Boolean  @default(true)
  collectClicks      Boolean  @default(true)
  collectConversions Boolean  @default(true)
  collectGeo         Boolean  @default(false)
  collectAge         Boolean  @default(false)
  retentionDays      Int      @default(365)
  dailyReport        Boolean  @default(true)
  weeklyReport       Boolean  @default(true)
  monthlyReport      Boolean  @default(true)
  reportFormat       String   @default("pdf")
  reportTime         String   @default("09:00")
  dashboardWidgets   String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime
}

model AntidetectBrowser {
  id                    String    @id
  browserType           String
  profileId             String    @unique
  profileName           String?
  accountId             String?
  proxyId               String?
  platform              String?
  proxyType             String?
  proxyHost             String?
  proxyPort             Int?
  proxyUsername         String?
  proxyPassword         String?
  userAgent             String?
  screenResolution      String?
  timezone              String?
  language              String?
  geolocation           String?
  webglRenderer         String?
  fingerprint           String?
  fingerprintSettings   String?
  status                String    @default("available")
  lastUsedAt            DateTime?
  currentSessionStarted DateTime?
  sessionsCount         Int       @default(0)
  cpuUsage              Float     @default(0)
  memoryUsage           Float     @default(0)
  networkUsage          Float     @default(0)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime
  Account               Account?  @relation(fields: [accountId], references: [id])
}

model ApiKey {
  id            String    @id
  name          String
  provider      String
  key           String
  requestsCount Int       @default(0)
  lastUsedAt    DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime
  userId        String
  User          User      @relation(fields: [userId], references: [id])
}

model AuctionBid {
  id                 String             @id
  auctionId          String
  bidderId           String
  amount             Float
  createdAt          DateTime           @default(now())
  WarmChannelAuction WarmChannelAuction @relation(fields: [auctionId], references: [id])
}

model AudienceEmotionAnalysis {
  id               String   @id
  sourceType       String
  sourceId         String?
  periodStart      DateTime
  periodEnd        DateTime
  primaryEmotion   String
  emotionScores    String?
  mood             String
  moodScore        Float    @default(0)
  emotionTrend     String?
  commentsAnalyzed Int      @default(0)
  positiveComments Int      @default(0)
  negativeComments Int      @default(0)
  neutralComments  Int      @default(0)
  positiveTopics   String?
  negativeTopics   String?
  recommendedTone  String?
  avoidTopics      String?
  aiInsights       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime

  @@index([primaryEmotion])
  @@index([sourceType])
}

model AutoChannelCreator {
  id                 String    @id
  channelId          String?
  channelName        String
  channelUsername    String?
  niche              String
  targetAudience     String?
  contentStrategy    String?
  postsGenerated     Int       @default(0)
  targetSubscribers  Int       @default(1000)
  currentSubscribers Int       @default(0)
  growthMethod       String
  estimatedValue     Float     @default(0)
  status             String    @default("creating")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime
  soldAt             DateTime?
}

model AutoFormatTester {
  id            String    @id
  campaignId    String?
  formats       String?
  budgetPercent Float     @default(0.05)
  results       String?
  winnerFormat  String?
  status        String    @default("running")
  startDate     DateTime?
  endDate       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime
}

model AutoRepost {
  id               String   @id
  sourceType       String
  sourceId         String?
  sourceUrl        String?
  keywords         String?
  minViews         Int?
  minEngagement    Float?
  rewriteContent   Boolean  @default(true)
  generateNewImage Boolean  @default(true)
  status           String   @default("active")
  targetChannelId  String?
  targetPlatform   String
  repostsCount     Int      @default(0)
  avgPerformance   Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime

  @@index([sourceType])
  @@index([status])
}

model AutoScalingSettings {
  id                 String    @id
  campaignId         String    @unique
  roiThreshold       Float     @default(150)
  checkIntervalHours Int       @default(3)
  scaleFactor        Float     @default(1.5)
  maxBudget          Float?
  maxChannels        Int?
  enabled            Boolean   @default(false)
  lastScaleAt        DateTime?
  scaleCount         Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime
}

model AutoStoryRule {
  id               String   @id
  profileId        String?
  minProfileClicks Int      @default(1)
  delayMinutes     Int      @default(5)
  storyTemplate    String?
  aiGenerateImage  Boolean  @default(true)
  offerLink        String?
  linkText         String?
  triggeredCount   Int      @default(0)
  successCount     Int      @default(0)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime
}

model AutomationRule {
  id              String   @id
  name            String
  isActive        Boolean  @default(true)
  conditionType   String
  conditionConfig String
  actionType      String
  actionConfig    String
  createdAt       DateTime @default(now())
  updatedAt       DateTime
  userId          String
  campaignId      String?
}

model BatchOperation {
  id              String    @id
  userId          String
  operationType   String
  type            String?
  action          String
  entityType      String    @default("generic")
  entityIds       String?
  targetIds       String?
  parameters      String?
  status          String    @default("pending")
  totalItems      Int       @default(0)
  processedItems  Int       @default(0)
  successItems    Int       @default(0)
  failedItems     Int       @default(0)
  progress        Int       @default(0)
  progressPercent Float     @default(0)
  result          String?
  results         String?
  errors          String?
  error           String?
  startedAt       DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  estimatedEndAt  DateTime?
  canCancel       Boolean   @default(true)
  cancelReason    String?
  entityIdsList   String?
  targetIdsList   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime

  @@index([operationType])
  @@index([status])
  @@index([userId])
}

model BestTimePrediction {
  id              String    @id
  platform        String
  influencerId    String?
  channelId       String?
  analysisPeriod  Int       @default(30)
  bestTimes       String?
  weekdayScores   String?
  hourlyScores    String?
  recommendations String?
  accuracyScore   Float?
  postsAnalyzed   Int       @default(0)
  lastAnalyzed    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime

  @@index([influencerId])
  @@index([platform])
}

model BlacklistSettings {
  id                String   @id
  userId            String
  forbiddenWords    String?
  forbiddenChannels String?
  forbiddenTopics   String?
  whitelistOnly     Boolean  @default(false)
  whitelist         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime
}

model BlueskyIntegration {
  id             String   @id
  handle         String   @unique
  did            String?
  targetKeywords String?
  postTemplates  String?
  dailyLimit     Int      @default(50)
  hourlyLimit    Int      @default(10)
  totalPosts     Int      @default(0)
  totalComments  Int      @default(0)
  telegramClicks Int      @default(0)
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime
}

model BotDetection {
  id                  String   @id
  channelId           String
  channelName         String?
  botPercentage       Float    @default(0)
  realUsersPercentage Float    @default(0)
  suspiciousAvatars   Int      @default(0)
  genericNames        Int      @default(0)
  lowActivityUsers    Int      @default(0)
  analyzedUsersCount  Int      @default(0)
  flaggedUsers        String?
  recommendation      String?
  createdAt           DateTime @default(now())
}

model BudgetSettings {
  id             String   @id
  totalBudget    Float    @default(0)
  spentBudget    Float    @default(0)
  currency       String   @default("RUB")
  deepseekBudget Float    @default(50)
  deepseekSpent  Float    @default(0)
  dailyLimit     Float?
  cpaLimit       Float?
  notifyAt50     Boolean  @default(true)
  notifyAt80     Boolean  @default(true)
  notifyAt90     Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime
  userId         String   @unique
  User           User     @relation(fields: [userId], references: [id])
}

model BundleReview {
  id             String         @id
  bundleId       String
  userId         String
  rating         Int
  comment        String?
  buyerROI       Float?
  createdAt      DateTime       @default(now())
  CampaignBundle CampaignBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
}

model Campaign {
  id                 String               @id
  name               String
  description        String?
  type               String
  niche              String?
  geo                String?
  status             String               @default("draft")
  budget             Float                @default(0)
  spent              Float                @default(0)
  currency           String               @default("RUB")
  leadsCount         Int                  @default(0)
  conversions        Int                  @default(0)
  revenue            Float                @default(0)
  startDate          DateTime?
  endDate            DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime
  userId             String
  User               User                 @relation(fields: [userId], references: [id])
  CampaignAnalytics  CampaignAnalytics[]
  CampaignInfluencer CampaignInfluencer[]
  CampaignOffer      CampaignOffer[]
  Post               Post[]

  @@index([createdAt])
  @@index([geo])
  @@index([niche])
  @@index([status])
  @@index([userId])
}

model CampaignAnalytics {
  id          String   @id
  date        DateTime
  impressions Int      @default(0)
  clicks      Int      @default(0)
  leads       Int      @default(0)
  conversions Int      @default(0)
  spent       Float    @default(0)
  revenue     Float    @default(0)
  createdAt   DateTime @default(now())
  campaignId  String
  Campaign    Campaign @relation(fields: [campaignId], references: [id])

  @@unique([campaignId, date])
}

model CampaignBundle {
  id           String         @id
  authorId     String
  name         String
  description  String?
  config       String
  price        Float          @default(0)
  currency     String         @default("RUB")
  salesCount   Int            @default(0)
  revenue      Float          @default(0)
  avgRating    Float          @default(0)
  reviewsCount Int            @default(0)
  authorROI    Float?
  authorProfit Float?
  status       String         @default("draft")
  isVerified   Boolean        @default(false)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime
  BundleReview BundleReview[]
}

model CampaignExtended {
  id                    String   @id
  campaignId            String   @unique
  offerType             String   @default("crypto")
  link                  String?
  autoReplaceOnBan      Boolean  @default(true)
  maxCommentsPerAccount Int      @default(50)
  selectedAccounts      String?
  postingMode           String   @default("new")
  delayMin              Int      @default(30)
  delayMax              Int      @default(120)
  delayRandom           Boolean  @default(true)
  useUniqueText         Boolean  @default(true)
  useDeepSeek           Boolean  @default(true)
  deepSeekTemperature   Float    @default(0.7)
  maxCostPerLead        Float    @default(100)
  workTimeStart         String   @default("09:00")
  workTimeEnd           String   @default("21:00")
  createdAt             DateTime @default(now())
  updatedAt             DateTime
}

model CampaignInfluencer {
  campaignId   String
  influencerId String
  role         String     @default("primary")
  status       String     @default("active")
  Influencer   Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  Campaign     Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@id([campaignId, influencerId])
}

model CampaignOffer {
  campaignId  String
  offerId     String
  isPrimary   Boolean  @default(false)
  abTestGroup String?
  Offer       Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  Campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@id([campaignId, offerId])
}

model CampaignSettings {
  id                  String   @id
  campaignId          String   @unique
