  usedCount         Int           @default(0)
  
  // Сессия и куки
  sessionData       String?       // JSON with cookies, tokens
  lastLoginAt       DateTime?
  
  // Proxy
  proxyId           String?
  proxyHost         String?
  proxyPort         Int?
  proxyUsername     String?
  proxyPassword     String?
  
  // sticky session
  stickyProxy       String?
  
  // Метаданные
  notes             String?
  tags              String?       // JSON array
  
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @default(now())
  expiresAt         DateTime?
  
  EmailService      EmailService  @relation(fields: [serviceId], references: [id])

  @@index([email])
  @@index([status])
  @@index([serviceId])
}

// Очередь регистрации почтовых аккаунтов
model EmailRegistrationQueue {
  id                String    @id
  service           String    // gmail, yandex, mailru, etc.
  status            String    @default("pending")  // pending, in_progress, completed, failed
  priority          Int       @default(5)
  
  // Параметры регистрации
  firstName         String?
  lastName          String?
  customUsername    String?
  customPassword    String?
  recoveryEmail     String?
  
  // Результат
  resultEmail       String?
  resultPassword    String?
  accountId         String?
  
  // Ошибки
  errorMessage      String?
  retryCount        Int       @default(0)
  maxRetries        Int       @default(3)
  
  // Временные метки
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @default(now())

  @@index([status])
  @@index([service])
  @@index([priority])
}
